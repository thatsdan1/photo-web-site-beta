{
    "rewrites": [
      { "source": "/api/(.*)", "destination": "/api/index.js" },
      { "source": "/auth/(.*)", "destination": "/auth/index.js" },
      { "source": "/login", "destination": "/login/index.js" },
      { "source": "/logout", "destination": "/logout/index.js" },
      { "source": "/register", "destination": "/register/index.js" },
      { "source": "/profile", "destination": "/profile/index.js" },
      { "source": "/profile/(.*)", "destination": "/profile/index.js" },
      { "source": "/admin", "destination": "/admin/index.js" },
      { "source": "/admin/(.*)", "destination": "/admin/index.js" },
      { "source": "/admin/users", "destination": "/admin/users/index.js" },
      { "source": "/admin/users/(.*)", "destination": "/admin/users/index.js" },
      { "source": "/admin/roles", "destination": "/admin/roles/index.js" },
      { "source": "/admin/roles/(.*)", "destination": "/admin/roles/index.js" },
      { "source": "/admin/permissions", "destination": "/admin/permissions/index.js" },
      { "source": "/admin/permissions/(.*)", "destination": "/admin/permissions/index.js" },
      { "source": "/admin/roles/permissions", "destination": "/admin/roles/permissions/index.js" },
      { "source": "/admin/roles/permissions/(.*)", "destination": "/admin/roles/permissions/index.js" },
      { "source": "/admin/users/roles", "destination": "/admin/users/roles/index.js" },
      { "source": "/admin/users/roles/(.*)", "destination": "/admin/users/roles/index.js" },
      { "source": "/admin/roles/users", "destination": "/admin/roles/users/index.js" },
      { "source": "/admin/roles/users/(.*)", "destination": "/admin/roles/users/index.js" },
      { "source": "/admin/roles/permissions", "destination": "/admin/roles/permissions/index.js" }
    ]
  }
  